{
  "name": "web-react",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:docker": "docker build -t web-react-app .",
    "build:baseline:docker": "npm run build:docker -- --build-arg BUNDLE_STATS_BASELINE=true",
    "build:client": "npm run i18n:manage && vite build --outDir dist/client",
    "build:server": "vite build --ssr src/ui/app/entries/main-server.tsx --outDir dist/server",
    "build:storybook": "storybook build -o dist-storybook",
    "bundle-stats:fetch-actual-baseline": "ts-node --project ./scripts/tsconfig.json ./scripts/bundle-stats/fetch-actual-baseline.ts",
    "bundle-stats:get-from-docker": "ts-node --project ./scripts/tsconfig.json ./scripts/bundle-stats/get-bundle-stats.ts --docker-image web-react-app",
    "bundle-stats:get-from-docker:baseline": "npm run bundle-stats:get-from-docker -- --baseline",
    "circular-deps": "node scripts/npm-run-all.js --parallel circular-deps:*",
    "circular-deps:ui": "madge --circular --extensions ts,tsx --ts-config src/ui/tsconfig.json src/ui",
    "dev": "nodemon -w src/server -x tsx src/server/main.ts",
    "generate-types": "ts-node --project ./scripts/tsconfig.json ./scripts/generate-db-types.ts",
    "i18n:extract": "formatjs extract \"src/**/*.{ts,tsx}\" --ignore=\"**/*.d.ts\" --out-file src/locales/extracted.json --id-interpolation-pattern [sha512:contenthash:base64:6]",
    "i18n:manage": "ts-node --project ./scripts/tsconfig.json scripts/manage-translations.ts",
    "lint": "eslint --concurrency=auto --config ./eslint.config.mjs .",
    "lint:performance": "cross-env TIMING=1 npm run lint",
    "lint:fix": "npm run lint -- --fix",
    "playwright:install": "npx playwright install --with-deps",
    "prepare": "husky",
    "preview": "cross-env NODE_ENV=production nodemon -x tsx src/server/main.ts",
    "sanitize-har": "ts-node --project ./scripts/tsconfig.json ./scripts/sanitize-har-files.ts",
    "storybook": "storybook dev --no-open -p 6006",
    "stylelint": "stylelint \"**/*.{css,scss}\" \".storybook/**/*.{css,scss}\"",
    "stylelint:fix": "npm run stylelint -- --fix",
    "test:component": "playwright test --config=tests/component/playwright.config.ts",
    "test:component:docker": "docker compose run --rm playwright-ct test:component",
    "test:component:update": "npm run test:component -- -update",
    "test:component:update:docker": "docker compose run --rm playwright-ct test:component:update",
    "test:integration": "playwright test --config=tests/app/integration/playwright.config.ts",
    "test:integration:docker": "docker compose run --rm playwright test:integration",
    "test:integration:update": "cross-env UPDATE=1 npm run test:integration -- -update",
    "test:integration:update:docker": "docker compose run --rm playwright test:integration:update",
    "test:unit": "vitest",
    "test:unit:ci": "vitest --run",
    "typecheck": "tsc --build ./tsconfig.json",
    "knip": "knip --config ./knip.config.ts"
  },
  "lint-staged": {
    "**/*.{css,scss}": [
      "stylelint --fix"
    ],
    "**/*": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@bem-react/classname": "^1.6.0",
    "@gravity-ui/data-source": "^0.6.1",
    "@heroui/avatar": "^2.2.22",
    "@heroui/button": "^2.2.27",
    "@heroui/card": "^2.2.25",
    "@heroui/checkbox": "^2.3.27",
    "@heroui/chip": "^2.2.22",
    "@heroui/dropdown": "^2.3.27",
    "@heroui/input": "^2.4.28",
    "@heroui/modal": "^2.2.24",
    "@heroui/popover": "^2.3.27",
    "@heroui/select": "^2.4.28",
    "@heroui/spinner": "^2.2.24",
    "@heroui/system": "^2.4.23",
    "@heroui/table": "^2.2.27",
    "@heroui/tabs": "^2.2.24",
    "@heroui/theme": "^2.4.23",
    "@heroui/toast": "^2.0.17",
    "@heroui/use-theme": "^2.1.10",
    "@normy/react-query": "^0.20.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "^5.76.1",
    "@tanstack/react-table": "^8.21.3",
    "classnames": "^2.5.1",
    "compression": "^1.8.0",
    "final-form": "^4.20.10",
    "final-form-arrays": "^3.1.0",
    "framer-motion": "^12.23.24",
    "lodash": "^4.17.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-final-form": "^6.5.9",
    "react-final-form-arrays": "^3.1.4",
    "react-icons": "^5.5.0",
    "react-intl": "^7.1.11",
    "react-router": "^7.5.3",
    "sirv": "^3.0.1",
    "tailwindcss": "^4.1.16",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@formatjs/cli": "^6.7.1",
    "@gravity-ui/eslint-config": "^4.0.1",
    "@playwright/experimental-ct-react": "^1.52.0",
    "@playwright/test": "^1.52.0",
    "@storybook/addon-a11y": "^9.0.3",
    "@storybook/addon-docs": "^9.0.3",
    "@storybook/addon-vitest": "^9.0.8",
    "@storybook/react": "^9.0.4",
    "@storybook/react-vite": "^9.0.3",
    "@storybook/theming": "^8.6.14",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "^5.0.6",
    "@types/har-format": "^1.2.16",
    "@types/lodash": "^4.17.17",
    "@types/node": "^22.15.29",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^3.1.4",
    "@vueless/storybook-dark-mode": "^9.0.10",
    "babel-plugin-formatjs": "^10.5.39",
    "cookie-parser": "^1.4.7",
    "cross-env": "^7.0.3",
    "crypto": "^1.0.1",
    "dotenv": "^16.5.0",
    "eslint": "^9.39.1",
    "eslint-plugin-formatjs": "^5.3.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-import-newlines": "^1.4.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-storybook": "^9.0.3",
    "express": "^5.1.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "knip": "^5.61.3",
    "lint-staged": "^16.1.0",
    "madge": "^8.0.0",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "rollup-plugin-bundle-stats": "^4.21.0",
    "sass": "^1.87.0",
    "storybook": "^9.0.3",
    "stylelint": "^16.20.0",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vitest": "^3.1.4"
  }
}