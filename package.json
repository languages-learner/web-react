{
  "name": "web-react",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "test:unit": "nx run-many -t test:unit",
    "typecheck": "nx run-many -t typecheck",
    "lint": "nx run-many -t lint",
    "stylelint": "nx run-many -t stylelint",
    "test:unit:ci": "nx run-many -t test:unit:ci",
    "circular-deps": "nx run-many -t circular-deps",
    "knip": "knip --config ./knip.config.ts",
    "sanitize-har": "ts-node ./scripts/sanitize-har-files.ts",
    "component-tests:build-image": "ts-node ./scripts/component-tests/build-image.ts",
    "component-tests:test": "ts-node ./scripts/component-tests/run-tests.ts",
    "deps:check": "syncpack lint --dependency-types prod,dev,peer",
    "deps:fix": "syncpack fix --dependency-types prod,dev,peer",
    "deps:list": "syncpack list --dependency-types prod,dev,peer",
    "deps:update": "syncpack update --dependency-types prod,dev,peer"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.7.1",
    "@languages-learner/har-sanitizer": "workspace:*",
    "@tanstack/eslint-config": "^0.3.3",
    "@types/node": "^22.15.29",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^3.1.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-formatjs": "^5.3.1",
    "eslint-plugin-import-newlines": "^1.4.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^9.0.3",
    "knip": "5.61.3",
    "madge": "^8.0.0",
    "npm-run-all": "^4.1.5",
    "nx": "22.1.3",
    "postcss": "^8.4.29",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^9.0.3",
    "stylelint": "^16.20.0",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "syncpack": "^14.0.0",
    "ts-node": "11.0.0-beta.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.1.4",
    "@playwright/experimental-ct-react": "1.52.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.0",
      "zod": "^3.25.23",
      "@react-aria/utils": "^3.33.0",
      "@react-aria/interactions": "^3.27.0",
      "@react-aria/selection": "^3.27.1",
      "@react-aria/focus": "^3.21.4",
      "@react-aria/i18n": "^3.12.15",
      "@react-aria/form": "^3.1.4",
      "@react-aria/visually-hidden": "^3.8.30",
      "@react-stately/selection": "^3.20.8",
      "@react-stately/collections": "^3.12.9",
      "@react-stately/form": "^3.2.3",
      "@react-stately/utils": "^3.11.0",
      "@heroui/form": "^2.1.31",
      "@heroui/ripple": "^2.2.21",
      "clsx": "^2.1.1"
    },
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
