{
  "name": "web-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run i18n:manage && vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint --config ./eslint.config.js .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"**/*.scss\"",
    "stylelint:fix": "stylelint \"**/*.scss\" --fix",
    "i18n:extract": "formatjs extract \"src/**/*.{ts,tsx}\" --ignore=\"**/*.d.ts\" --out-file src/locales/extracted.json --id-interpolation-pattern [sha512:contenthash:base64:6]",
    "i18n:manage": "node scripts/manage-translations.js",
    "prepare": "node .husky/install.mjs",
    "generate-types": "node ./scripts/generate-db-types.js",
    "test": "vitest",
    "test:ci": "vitest --run"
  },
  "lint-staged": {
    "**/*.scss": [
      "stylelint --fix"
    ],
    "**/*": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@bem-react/classname": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@gravity-ui/data-source": "^0.6.1",
    "@gravity-ui/icons": "^2.13.0",
    "@gravity-ui/table": "^1.10.1",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.76.1",
    "@tanstack/react-table": "^8.21.3",
    "classnames": "^2.5.1",
    "final-form": "^4.20.10",
    "final-form-arrays": "^3.1.0",
    "lodash": "^4.17.21",
    "react": "^19.1.0",
    "react-dom": "^19.0.0",
    "react-final-form": "^6.5.9",
    "react-final-form-arrays": "^3.1.4",
    "react-intl": "^7.1.11",
    "react-router": "^7.5.3",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@formatjs/cli": "^6.7.1",
    "@gravity-ui/eslint-config": "^4.0.1",
    "@gravity-ui/uikit": "^7.10.0",
    "@types/lodash": "^4.17.17",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-formatjs": "^10.5.38",
    "dotenv": "^16.5.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-formatjs": "^5.3.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-import-newlines": "^1.4.0",
    "eslint-plugin-prettier": "^5.3.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "prettier-eslint": "^16.4.1",
    "sass": "^1.87.0",
    "stylelint": "^16.20.0",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-recommended-scss": "^15.0.1",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.12.0",
    "supabase": "^2.22.12",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vitest": "^3.1.4"
  }
}
