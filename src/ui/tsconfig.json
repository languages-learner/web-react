{
  "extends": ["../../tsconfig.base.json"],
  "include": [".", "typings.d.ts", "../vite-env.d.ts"],
  "exclude": ["**/*.test.*", "**/*.test.*", "**/*.stories.*", "**/__stories__", "**/__tests__"],
  "references": [{ "path": "../locales" }, {"path":  "../shared"}],
  "compilerOptions": {

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@@/*": ["../../*"],
      "locales/*": ["../locales/*"],
      "shared/*": ["../shared/*"]
    }
  }
}
