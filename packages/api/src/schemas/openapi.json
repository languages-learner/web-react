            "example": "New"
          },
          "translations": {
            "description": "Array of translations",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TranslationResponseDto"
            }
          }
        },
        "required": [
          "id",
          "created_at",
          "updated_at",
          "user_id",
          "language",
          "text",
          "sort_id",
          "status",
          "translations"
        ]
      },
