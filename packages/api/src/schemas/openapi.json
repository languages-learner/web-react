          "id": {
            "type": "string",
            "description": "User ID",
            "example": "uuid"
          },
          "active_learning_language": {
            "type": "string",
            "description": "Active learning language code",
            "example": "en"
          },
          "interface_language": {
            "type": "string",
            "description": "Interface language code",
            "example": "en"
          },
          "native_language": {
            "type": "string",
            "description": "Native language code",
            "example": "ru"
          },
          "theme": {
            "type": "string",
            "description": "Theme preference",
            "enum": [
              "system",
              "dark",
              "light"
