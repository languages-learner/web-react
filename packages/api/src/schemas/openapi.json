            "example": "en"
          },
          "native_language": {
            "type": "string",
            "description": "Native language code",
            "example": "ru"
          },
          "theme": {
            "type": "string",
            "description": "Theme preference",
            "enum": [
              "system",
              "dark",
              "light"
            ],
            "example": "system"
          }
        }
      },
      "UpdateUserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID",
            "example": "uuid"
