{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "rootDir": ".",
    "outDir": "./dist",

    /* Bundler mode */
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",

    /* Referenced Project */
    "declaration": true,
    // Referenced project may not disable emit - https://github.com/microsoft/TypeScript/issues/49844
    "noEmit": false,
    "composite": true,
    "incremental": true,
    "disableReferencedProjectLoad": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  }
}
