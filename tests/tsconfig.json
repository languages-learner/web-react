{
  "extends": ["../tsconfig.ui.base.json"],
  "include": [
    "**/*",
    "../.storybook/dist/index.json",
    "../src/ui/**/*.test.*",
    "../src/ui/**/*.stories.*",
    "../src/ui/**/__stories__",
    "../src/ui/**/__tests__"
  ],
  "references": [{ "path": "../src/ui" }],
  "compilerOptions": {
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.tests.tsbuildinfo",

    "baseUrl": ".",
    "paths": {
      "@/tests/*": ["./*"]
    },
    "resolveJsonModule": true
  }
}
