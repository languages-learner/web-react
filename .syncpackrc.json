{
  "$schema": "https://raw.githubusercontent.com/JamieMason/syncpack/main/config.schema.json",
  "source": [
    "package.json",
    "apps/*/package.json",
    "packages/*/package.json"
  ],
  "versionGroups": [
    {
      "label": "Keep @heroui packages in sync",
      "packages": ["**"],
      "dependencies": ["@heroui/**"],
      "isIgnored": false
    }
  ]
}
