{
  "extends": [
    "./tsconfig.base.json"
  ],
  "compilerOptions": {
    "module": "ESNext",
    "rootDir": ".",
    "outDir": "./.typecheck",
    /* Referenced Project */
    "declaration": true,
    // Referenced project may not disable emit - https://github.com/microsoft/TypeScript/issues/49844
    "emitDeclarationOnly": true,
    "noEmitOnError": false,
    "composite": true,
    "incremental": true,
    "disableReferencedProjectLoad": true,
  }
}